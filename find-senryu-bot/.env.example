# FindSenryu4Discord — 環境変数設定テンプレート
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# =====================
# 必須設定
# =====================

# Discord Bot トークン（必須）
FINDSENRYU_DISCORD_TOKEN=

# =====================
# データベース設定
# =====================

# ドライバ: sqlite3 または postgres
FINDSENRYU_DATABASE_DRIVER=sqlite3

# SQLite ファイルパス（sqlite3 使用時）
FINDSENRYU_DATABASE_PATH=data/senryu.db

# PostgreSQL 接続文字列（postgres 使用時）
# FINDSENRYU_DATABASE_DSN=host=db user=findsenryu password=password dbname=findsenryu sslmode=disable

# =====================
# ログ設定
# =====================

FINDSENRYU_LOG_LEVEL=info
FINDSENRYU_LOG_FORMAT=json

# =====================
# 管理者設定（任意）
# =====================

# Bot 管理者の Discord ユーザー ID（カンマ区切り）
# FINDSENRYU_ADMIN_OWNER_IDS=123456789012345678,987654321098765432

# 管理コマンド登録先ギルド ID
# FINDSENRYU_ADMIN_GUILD_ID=

# リアルタイム通知送信先チャンネル ID（サーバー参加/脱退）
# FINDSENRYU_ADMIN_LOG_CHANNEL_ID=

# デイリーレポート送信先チャンネル ID
# FINDSENRYU_ADMIN_REPORT_CHANNEL_ID=

# /contact コマンドのお問い合わせ通知先チャンネル ID
# FINDSENRYU_ADMIN_CONTACT_CHANNEL_ID=

# =====================
# HTTPサーバー設定
# =====================

FINDSENRYU_SERVER_ENABLED=true
FINDSENRYU_SERVER_PORT=9090

# =====================
# バックアップ設定（SQLite のみ）
# =====================

FINDSENRYU_BACKUP_ENABLED=false
FINDSENRYU_BACKUP_INTERVAL_HOUR=24
FINDSENRYU_BACKUP_PATH=data/backups
FINDSENRYU_BACKUP_MAX_BACKUPS=7

# =====================
# 暗号化設定（任意）
# =====================

# AES-256-GCM キー（hex エンコード 32 バイト）
# 生成: openssl rand -hex 32
# 一度設定したキーは削除しないこと（データが読めなくなります）
# FINDSENRYU_ENCRYPTION_KEY=
